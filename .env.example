# PrediQs AI — Environment Variables
# Copy this file and add values to Replit Secrets (lock icon in sidebar)
# Never commit real secrets to version control.

# ─── CRITICAL (app breaks without these) ──────────────────────────────────────

# PostgreSQL connection string — provided automatically by Replit Database
DATABASE_URL=

# Secret key for signing JWT auth tokens (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=

# Anthropic Claude API key — get from console.anthropic.com → API Keys
# Used for AI predictions (ESPN + Claude) and the AI chat assistant
ANTHROPIC_API_KEY=

# ─── OPTIONAL (app degrades gracefully without these) ──────────────────────────

# Stripe — payment processing for Pro/Elite subscriptions
# Get from dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create products at dashboard.stripe.com → Products
# PrediQs Pro: $9.99/month recurring
STRIPE_PRICE_PRO=
# PrediQs Elite: $24.99/month recurring
STRIPE_PRICE_ELITE=

# ─── MOBILE / EXPO (set automatically by Replit) ──────────────────────────────

# Your Replit app domain — set automatically, do not set manually
# EXPO_PUBLIC_DOMAIN=your-repl-name.username.repl.co
# REPLIT_DEV_DOMAIN=...
# REPLIT_EXPO_DEV_DOMAIN=...
