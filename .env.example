# PrediQs AI — Environment Variables
# Copy these to Replit Secrets (lock icon in sidebar).
# Never commit real secrets to version control.
# Visit /setup in the app (admin only) for step-by-step setup instructions.

# ─── CRITICAL (app breaks without these) ──────────────────────────────────────

# PostgreSQL connection string — auto-provided by Replit Database tab
DATABASE_URL=

# JWT signing secret — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Anthropic Claude API key — console.anthropic.com → API Keys → Create Key
# Used for AI predictions (ESPN + Claude) and the AI chat assistant
ANTHROPIC_API_KEY=

# API-Sports — live scores, fixtures, standings across 30+ sports
# api-sports.io → Dashboard → My Account → API Key  (100 req/day free)
API_SPORTS_KEY=

# The Odds API — real-time betting odds from 40+ sportsbooks
# the-odds-api.com → Account → API Key  (500 req/month free)
ODDS_API_KEY=

# ─── OPTIONAL (app degrades gracefully without these) ──────────────────────────

# News API — sports headlines from 150+ sources for AI prediction context
# newsapi.org → Account → API Key  (100 req/day free)
NEWS_API_KEY=

# Weather API — outdoor game conditions for NFL, MLB, Soccer predictions
# weatherapi.com → Dashboard → API Key  (1M calls/month free)
WEATHER_API_KEY=

# ─── STRIPE (payments) ────────────────────────────────────────────────────────

# Stripe server-side secret key — dashboard.stripe.com → Developers → API Keys → Secret key
STRIPE_SECRET_KEY=

# Stripe publishable key for mobile SDK — dashboard.stripe.com → Developers → API Keys → Publishable key
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret — dashboard.stripe.com → Webhooks → Add endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# Stripe Price ID for PrediQs Pro ($9.99/mo) — dashboard.stripe.com → Products → create → copy Price ID
STRIPE_PRICE_PRO=

# Stripe Price ID for PrediQs Elite ($24.99/mo) — dashboard.stripe.com → Products → create → copy Price ID
STRIPE_PRICE_ELITE=

# ─── PUSH NOTIFICATIONS ───────────────────────────────────────────────────────

# OneSignal App ID — onesignal.com → New App → Settings → Keys & IDs
ONESIGNAL_APP_ID=

# OneSignal REST API Key — onesignal.com → Settings → Keys & IDs → REST API Key
ONESIGNAL_API_KEY=

# ─── EMAIL ────────────────────────────────────────────────────────────────────

# Resend API key — resend.com → API Keys → Create API Key  (3,000 emails/month free)
RESEND_API_KEY=

# ─── APP CONFIG ───────────────────────────────────────────────────────────────

# Your deployed Replit app URL — used for Stripe webhooks, email links, deep links
# e.g. https://prediqs-ai.yourusername.replit.app
EXPO_PUBLIC_APP_URL=

# Google Analytics 4 Measurement ID — analytics.google.com → Property → Data Streams
# e.g. G-XXXXXXXXXX
GOOGLE_ANALYTICS_ID=
